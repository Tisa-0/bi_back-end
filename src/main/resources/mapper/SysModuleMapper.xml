<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rightmanage.mapper.SysModuleMapper">

  <select id="selectByModuleCode" resultType="com.rightmanage.entity.SysModule">
    SELECT * FROM sys_module
    WHERE module_code = #{moduleCode}
    LIMIT 1
  </select>

</mapper>
