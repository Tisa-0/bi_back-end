<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rightmanage.mapper.flow.FlowInstanceMapper">

  <select id="selectByInstanceId" resultType="com.rightmanage.entity.flow.FlowInstance">
    SELECT * FROM flow_instance
    WHERE instance_id = #{instanceId}
      AND deleted = 0
    LIMIT 1
  </select>

</mapper>
